# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Spotify API Credentials
SPOTIFY_ID=your_spotify_client_id_here
SPOTIFY_SECRET=your_spotify_client_secret_here

# YouTube Cookie File (required for age-restricted videos)
# Export cookies from your browser using an extension like "Get cookies.txt"
# Format: full path to your cookies.txt file
YT_COOKIE_FILE=

# Proxy Configuration (optional)
# Example formats:
# HTTP_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://username:password@proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080
# SOCKS_PROXY=socks5://proxy.example.com:1080
HTTP_PROXY=
HTTPS_PROXY=
SOCKS_PROXY=